# Copy to .env and fill in. The defaults below run the full app locally with mocks.

# SQLite for local dev. For staging/prod, set a Postgres URL and change
# prisma/schema.prisma datasource provider to "postgresql".
DATABASE_URL="file:./dev.db"

# Session signing secret. Generate one: openssl rand -base64 32
AUTH_SECRET="dev-only-insecure-secret-change-me"

# ─── Real partner credentials (leave blank to use mocks) ───
# SMS (MSG91 / Twilio)
# SMS_API_KEY=
# CIBIL / bureau
# BUREAU_API_KEY=
# KYC vendor (Karza / IDfy / Hyperverge / Signzy)
# KYC_API_KEY=
# Payment aggregator (Razorpay / Cashfree)
# PSP_KEY_ID=
# PSP_KEY_SECRET=
# PSP_WEBHOOK_SECRET=
# NBFC lending partner
# NBFC_API_BASE=
# NBFC_API_KEY=
