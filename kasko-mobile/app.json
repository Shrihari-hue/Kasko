{
  "expo": {
    "name": "Kasko",
    "slug": "kasko",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kasko",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kasko.app"
    },
    "android": {
      "package": "com.kasko.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1419"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F1419"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBase": "https://kasko-production.up.railway.app",
      "eas": {
        "projectId": "330b431f-7513-4a36-bd03-4a8e6eff995a"
      },
      "router": {
        "origin": false
      }
    }
  }
}
